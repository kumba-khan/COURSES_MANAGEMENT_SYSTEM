<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
{{>actionMessage}}

<body>
    
    <header class="header">
        <div class="header-left">
          <h2 class="page-title">Dashboard</h2>
        </div>
        <div class="header-right">
          <span class="user-name">{{user.email}}</span>
          <a href="/auth/logout" class="btn btn-outline btn-sm">Logout</a>
        </div>
      </header>

      <div class="content">
        <div class="dashboard">
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-icon">👥</div>
              <div class="stat-info">
                <span class="stat-value">24</span>
                <span class="stat-label">Total Students</span>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-icon">✅</div>
              <div class="stat-info">
                <span class="stat-value">18</span>
                <span class="stat-label">Active Students</span>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-icon">📚</div>
              <div class="stat-info">
                <span class="stat-value">4</span>
                <span class="stat-label">Total Courses</span>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-icon">📋</div>
              <div class="stat-info">
                <span class="stat-value">42</span>
                <span class="stat-label">Marked Today</span>
              </div>
            </div>
          </div>

          <div class="dashboard-grid">
            <div class="card">
              <div class="card-header">
                <h3>Quick Actions</h3>
              </div>
              <div class="quick-actions">
                <a href="attendance-mark.html" class="btn btn-primary">Mark Attendance</a>
                <a href="students-create.html" class="btn btn-secondary">Add Student</a>
                <a href="courses-list.html" class="btn btn-secondary">View Courses</a>
                <a href="reports-absences.html" class="btn btn-outline">View Absences</a>
              </div>
            </div>

            <div class="card">
              <div class="card-header">
                <h3>Recent Activity</h3>
              </div>
              <ul class="activity-list">
                <li class="activity-item">
                  <span class="activity-text">Amadou Jallow marked present for Web Development</span>
                  <span class="activity-time">2 hours ago</span>
                </li>
                <li class="activity-item">
                  <span class="activity-text">Fatou Ceesay marked absent for Database Management</span>
                  <span class="activity-time">3 hours ago</span>
                </li>
                <li class="activity-item">
                  <span class="activity-text">Lamin Touray marked late for Programming Basics</span>
                  <span class="activity-time">4 hours ago</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <p class="text-center mt-md"><a href="index.html">← Back to Demo Index</a></p>
      </div>

</body>
</html>