<header class="header">
        <div class="header-left"><h2 class="page-title">{{student.name}}</h2></div>
        <div class="header-right">
          <span class="user-name">{{user.email}}</span>
          <a href="/auth/logout" class="btn btn-outline btn-sm">Logout</a>
        </div>
      </header>

      <div class="content">
        <div class="card">
          <div class="card-header">
            <h2>{{student.name}}</h2>
            <div class="flex gap-sm">
              <a href="/students/{{student._id}}/report" class="btn btn-secondary">View Report</a>
              <a href="/students/{{student._id}}/edit" class="btn btn-outline">Edit</a>
              <a href="/students" class="btn btn-outline">Back</a>
            </div>
          </div>

          <div class="student-details mb-lg">
            <div class="detail-row">
              <span class="detail-label">Email:</span>
              <span>{{student.email}}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Phone:</span>
              <span>{{student.phone}}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Status:</span>
              <span class="badge badge-success">{{student.status}}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Enrolled:</span>
              <span>{{formatDate student.enrolledDate}}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Attendance Rate:</span>
              <span>87% (23 records)</span>
            </div>
          </div>

