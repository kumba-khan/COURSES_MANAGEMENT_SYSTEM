<header class="header">
        <div class="header-left"><h2 class="page-title">Edit Student</h2></div>
        <div class="header-right">
          <span class="user-name">admin@attendance.com</span>
          <a href="/auth/login" class="btn btn-outline btn-sm">Logout</a>
        </div>
      </header>
      {{>actionMessage}}
      <div class="content">
        <div class="card">
          <div class="card-header">
            <h2>Edit Student: {{student.name}}</h2>
            <a href="/students" class="btn btn-outline">Back to Student</a>
          </div>

          <form action="/students/{{student._id}}?_method=PUT" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Full Name *</label>
                <input type="text" id="name" name="name" required value="{{student.name}}">
              </div>
              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required value="{{student.email}}">
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="phone">Phone</label>
                <input type="text" id="phone" name="phone" value="{{student.phone}}">
              </div>
              <div class="form-group">
                <label for="status">Status *</label>
                <select id="status" name="status" required>
                  <option value="active" {{#if (eq student.status "active")}}selected{{/if}}>Active</option>
                  <option value="inactive" {{#if (eq student.status "inactive")}}selected{{/if}}>Inactive</option>
                  <option value="graduated" {{#if (eq student.status "graduated")}}selected{{/if}}>Graduated</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <button type="submit" class="btn btn-primary">Update Student</button>
              <a href="/students" class="btn btn-outline">Cancel</a>
            </div>
          </form>
        </div>

        <p class="text-center mt-md"><a href="/">← Back to Demo Index</a></p>
      </div>

      <footer class="footer">
        <p>&copy; 2025 Attendance System - BDP Part 1 Project</p>
      </footer>