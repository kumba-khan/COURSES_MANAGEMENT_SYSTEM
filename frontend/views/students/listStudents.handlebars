<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Students - Attendance System</title>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
 
      <header class="header">
        <div class="header-left"><h2 class="page-title">Students</h2></div>
        <div class="header-right">
          <span class="user-name">{{user.email}}</span>
          <a href="/auth/login" class="btn btn-outline btn-sm">Logout</a>
        </div>
      </header>
      {{>actionMessage}}

      <div class="content">
        <div class="card">
          <div class="card-header">
            <h2>Students</h2>
            <a href="/students/create" class="btn btn-primary">Add Student</a>
          </div>

          <form class="form-inline mb-md">
            <div class="form-group">
              <input type="text" placeholder="Search by name or email..." value="">
            </div>
            <div class="form-group">
              <select>
                <option value="all">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="graduated">Graduated</option>
              </select>
            </div>
            <button type="button" class="btn btn-secondary">Filter</button>
          </form>

          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Status</th>
                  <th>Enrolled</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
               {{#each students}}
                <tr>
                  <td>{{this.name}}</td>
                  <td>{{this.email}}</td>
                  <td>{{this.phone}}</td>
                  <td>{{this.status}}</td>
                  <td>{{formatDate this.enrolledDate}}</td>
                  <td>
                    <a href="/students/{{this._id}}" class="btn btn-sm">View</a>
                    <a href="/students/{{this._id}}/edit" class="btn btn-sm btn-outline">Edit</a>
                    <form action="/students/{{this._id}}?_method=DELETE"
                          method="POST" 
                          style="display:inline;"
                          onsubmit="return confirm('Are you sure you want to delete this student?')"
>

                      <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                  </td>
                </tr>
                {{/each}}
               
              </tbody>
            </table>
          </div>
        </div>

        <p class="text-center mt-md"><a href="index.html">← Back to Demo Index</a></p>
      </div>

      <footer class="footer">
        <p>&copy; 2025 Attendance System - BDP Part 1 Project</p>
      </footer>
    </main>
  </div>
</body>
</html>
